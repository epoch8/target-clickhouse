{
    "streams": {
        "animals": {
            "engine": "MergeTree()",
            "partition_by": "created_at",
			"partition_type": "toDate",
            "order_by": ["id"],
            "force_fields": {
                "id": {"type": "Int32", "mode": "required"},
                "description": {"type": "String", "mode": "Nullable"},
                "verified": {"type": "Bool", "mode": "Nullable"},
                "views": {"type": "Int32", "mode": "Nullable"},
                "created_at": {"type": "DateTime64(0, 'UTC')", "mode": "required"},
                "upload_at": {"type": "DateTime64(0, 'UTC')", "mode": "required"}
            }
        }
    }
}
